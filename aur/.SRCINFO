pkgbase = releng-tool
	pkgdesc = A tool to create packages for select runtime environments (e.g. embedded targets)
	pkgver = 3.1.0
	pkgrel = 1
	url = https://releng.io/
	arch = any
	license = BSD-2-Clause
	makedepends = python-build
	makedepends = python-installer
	makedepends = python-setuptools
	makedepends = python-wheel
